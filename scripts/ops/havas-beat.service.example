[Unit]
Description=Havas Celery Beat Scheduler
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/media-buying-data/havas_collectors
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/var/www/media-buying-data/havas_collectors/.env
ExecStart=/usr/bin/env python -m celery -A havas_collectors.tasks.celery_app beat --loglevel=info
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
